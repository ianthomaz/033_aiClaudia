# deploy/env.prod.example
# Copie para env.prod e preencha. env.prod não é commitado (usado pelo start para deploy).

# --- Deploy (SSH) ---
DEPLOY_HOST=100.66.65.85
DEPLOY_USER=opc
DEPLOY_REMOTE_PATH=/home/opc/033_aiClaudia
# Opcional: usar ProxyJump (ex.: do pcVelho via Mac)
# DEPLOY_JUMP=ianthomaz@100.90.214.92
# Opcional: chave SSH para o host (ex.: no Mac use para BikeAnjoVM)
# DEPLOY_SSH_KEY=~/.ssh/id_ed25519

# --- App (produção) ---
NGINX_HOST=www.aiclaudia.com.br
FLASK_DEBUG=False

# Database
DB_NAME=aiclaudia
DB_USER=aiclaudia
DB_PASSWORD=

# AI (obrigatório). Chave em https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
CHATGPT_API_KEY=

# API (interno)
API_PORT=5000
