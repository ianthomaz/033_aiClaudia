# deploy/env.prod.example
# Copie para env.prod e preencha. env.prod não é commitado (usado pelo start para deploy).

# --- Deploy (SSH) ---
DEPLOY_HOST=100.66.65.85
DEPLOY_USER=opc
DEPLOY_REMOTE_PATH=/home/opc/033_aiClaudia
# Opcional: usar ProxyJump (ex.: do pcVelho via Mac)
# DEPLOY_JUMP=ianthomaz@100.90.214.92
# Opcional: chave SSH para o host (ex.: no Mac use para BikeAnjoVM)
# DEPLOY_SSH_KEY=~/.ssh/id_ed25519

# --- App (produção) ---
NGINX_HOST=www.aiclaudia.com.br
FLASK_DEBUG=False

# Database
DB_NAME=aiclaudia
DB_USER=aiclaudia
DB_PASSWORD=

# AI — Claudia fala SÓ pela LLM pessoal (ai2tcs / itcs-webplace) em llm.webplace.cc.
# Endpoint público HTTPS: POST /ask -> poll GET /status/{job_id} -> GET /result/{job_id} (Bearer).
# Docs (repo ai2tcs): docs/01-overview.md; docs/02-api-integration.md (/ask, auth, URLs);
#   docs/12-llm-fleet-rag-operations.md (checklist de LLM/RAG no lado do servidor).
LLM_API_URL=https://llm.webplace.cc
LLM_API_TOKEN=
LLM_PROJECT_ID=aiclaudia
# Aliases aceites pelo portal: fast | smart | compact | reasoner (ou tag Ollama explícita).
LLM_MODEL_ALIAS=smart
# LLM_ASK_TIMEOUT_SECONDS=120
# LLM_ASK_POLL_INTERVAL=0.8

# Com o trio LLM_API_URL + LLM_API_TOKEN + LLM_PROJECT_ID definido, só a ITCS é chamada (sem Gemini/GPT).
# LLM_DISABLE_COMMERCIAL=1 garante que Gemini/OpenAI ficam bloqueados mesmo se o token ITCS faltar.
LLM_DISABLE_COMMERCIAL=1
# Chaves comerciais ficam vazias de propósito (Claudia não usa pagas).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
CHATGPT_API_KEY=

# API (interno)
API_PORT=5000
