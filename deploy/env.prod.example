# deploy/env.prod.example
# Copie para env.prod e preencha. env.prod não é commitado (usado pelo start para deploy).

# --- Deploy (SSH) ---
DEPLOY_HOST=100.66.65.85
DEPLOY_USER=opc
DEPLOY_REMOTE_PATH=/home/opc/033_aiClaudia
# Opcional: usar ProxyJump (ex.: do pcVelho via Mac)
# DEPLOY_JUMP=ianthomaz@100.90.214.92
# Opcional: chave SSH para o host (ex.: no Mac use para BikeAnjoVM)
# DEPLOY_SSH_KEY=~/.ssh/id_ed25519

# --- App (produção) ---
NGINX_HOST=www.aiclaudia.com.br
FLASK_DEBUG=False

# Database
DB_NAME=aiclaudia
DB_USER=aiclaudia
DB_PASSWORD=

# AI — prefer ITCS (ai2tcs / itcs-webplace LLM API) when all three are set; Gemini/ChatGPT are fallback only.
# Docs (ai2tcs repo): docs/01-overview.md (index + scope); docs/02-api-integration.md (/ask, auth, URLs);
#   docs/12-llm-fleet-rag-operations.md (LLM/RAG ops checklist on the server side).
# From host: 127.0.0.1; from Docker Desktop API container to host LLM: host.docker.internal
LLM_API_URL=http://127.0.0.1:28471
LLM_API_TOKEN=
LLM_PROJECT_ID=aiclaudia
LLM_MODEL_ALIAS=smart
# LLM_ASK_TIMEOUT_SECONDS=120
# LLM_ASK_POLL_INTERVAL=0.8

# When LLM_API_URL + LLM_API_TOKEN + LLM_PROJECT_ID are set, only ITCS is called (no Gemini/GPT).
# Optional: LLM_DISABLE_COMMERCIAL=1 blocks Gemini/OpenAI even if ITCS is not configured.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
CHATGPT_API_KEY=

# API (interno)
API_PORT=5000
